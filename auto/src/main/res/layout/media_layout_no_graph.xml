<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:gravity="center">

    <!-- Adjusted Top Spacer (approx 15% height) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="15" />

    <!-- Glucose Trend (approx 50% height - MUCH LARGER) -->
    <LinearLayout
        android:id="@+id/layout_glucose_trend"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="50"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/glucose"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:gravity="center|end"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="1sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeMaxTextSize="2000sp"
            android:text="---"
            android:maxLines="1"
            android:paddingEnd="10dp" />

        <ImageView
            android:id="@+id/trendImage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:contentDescription="@string/trend"
            android:gravity="center|start"
            android:padding="0dp"
            android:src="@drawable/icon_question" />
    </LinearLayout>

    <!-- Bottom Spacer (35% height) to keep content prominent -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="35" />
</LinearLayout>
